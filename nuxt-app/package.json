{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "typecheck": "nuxt prepare && vue-tsc -b --noEmit",
    "test:visual": "playwright test --project=visual",
    "test:visualupdate": "playwright test --project=visual --update-snapshots",
    "test:e2e": "playwright test --project=e2e"
  },
  "dependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/image": "1.11.0",
    "@nuxtjs/robots": "5.7.1",
    "@nuxtjs/sitemap": "7.6.0",
    "@tailwindcss/vite": "4.2.4",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "@vueuse/core": "13.9.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-vue-next": "0.577.0",
    "motion-v": "1.10.3",
    "nuxt": "4.4.4",
    "reka-ui": "2.9.6",
    "shadcn-nuxt": "2.6.2",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "tw-animate-css": "1.4.0",
    "vue": "3.5.33",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "3.23.0",
    "@playwright/test": "1.59.1",
    "@types/node": "22.19.17",
    "@vue/test-utils": "2.4.10",
    "eslint": "9.39.4",
    "happy-dom": "18.0.1",
    "playwright-core": "1.59.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "vue-tsc": "3.2.7"
  }
}