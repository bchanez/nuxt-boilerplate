# URL publique du site (utilisée pour le SEO, les meta tags et les liens canoniques)
NUXT_SITE_URL=

# Clé API Google Places (pour récupérer les avis clients)
# https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=

# ID du lieu Google Maps (identifiant unique de l'établissement)
# Trouvable via https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=
